{
  "version": "0.2",
  "language": "en",
  "dictionaries": [
    "python",
    "softwareTerms",
    "typescript",
    "cpp"
  ],
  "ignorePaths": [
    "uv.lock",
    "tests/data/",
    "samples/"
  ],
  "ignoreRegExpList": [
    "/0x[0-9a-fA-F]+/g",
    // Hex literals like 0x00800000 as XRPL flag constants
    "/[0-9a-fA-F]{8,}/g",
    // Long hex strings like amendment hashes, indices in SHA512Half outputs everywhere
    "/r[a-zA-Z1-9]{24,34}/g", "/s[a-zA-Z1-9]{20,32}/g"
    // XRPL addresses and seeds like rHb9C.../ssyEb... Accounts/Seeds tests/fixtures
  ],
  "words": [
    "addopts",
    "addresscodec",
    "addrs",
    "ammcreate",
    "ammid",
    "amms",
    "autouse",
    "axyz",
    "basepoint",
