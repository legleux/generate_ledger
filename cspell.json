{
  "version": "0.2",
  "language": "en",
  "dictionaries": ["python", "softwareTerms", "typescript", "cpp"],
  "ignorePaths": [
    "uv.lock",
    "tests/",
    "samples/",
    "mkdocs.yml",
    ".pre-commit-config.yaml"
  ],
  "ignoreRegExpList": [
    "/0x[0-9a-fA-F]+/g",
    "/[0-9a-fA-F]{8,}/g",
    "/r[a-zA-Z1-9]{24,34}/g",
    "/s[a-zA-Z1-9]{20,32}/g",
    "/\\w*Backend\\w*/g"
  ],
  "words": [
    "addopts",
    "addresscodec",
    "addrs",
    "ammcreate",
    "ammid",
    "amms",
    "autouse",
    "axyz",
    "basepoint",
    "bitlen",
    "clawback",
    "coincurve",
    "complexipy",
    "conftest",
    "creds",
    "cuda",
    "cupy",
    "defaultno",
    "defaultyes",
    "devnet",
    "ecpy",
    "fastecdsa",
    "frombuffer",
    "frombytes",
    "fromhex",
    "healthcheck",
    "hotspot",
    "hotspots",
    "httpx",
    "hwcd",
    "initargs",
    "isnegative",
    "keygen",
    "keylet",
    "keypair",
    "keypairs",
    "ledgectl",
    "ledgen",
    "ledgend",
    "ledgerforge",
    "ledgergen",
    "ledgerentry",
    "ledgerfile",
    "legleux",
    "libsecp",
    "libsodium",
    "minversion",
    "mptid",
    "mptoken",
    "mptokens",
    "mpts",
    "nacl",
    "nftoken",
    "noinline",
    "notanumber",
    "nudb",
    "nvcc",
    "nvrtc",
    "optmeta",
    "paychan",
    "permissioned",
    "platformdirs",
    "preimage",
    "pubkeys",
    "pydantic",
    "pynacl",
    "pypa",
    "pytestconfig",
    "pytestmark",
    "recip",
    "remint",
    "ripemd",
    "ripesha",
    "rippleci",
    "rippled",
    "ripplestate",
    "ruamel",
    "sandboxed",
    "scalarmult",
    "scalarstring",
    "secho",
    "secp",
    "testpaths",
    "testpypi",
    "tobytes",
    "toolong",
    "topo",
    "trixie",
    "trustline",
    "trustlines",
    "trustset",
    "typer",
    "uppercased",
    "upstreaming",
    "webiny",
    "slidev",
    "seriph",
    "xchain",
    "xrpl",
    "xrpld"
  ],
  "overrides": [
    {
      "filename": "**/*.cu",
      "ignoreRegExpList": ["/ULL/g", "/__\\w+/g"]
    },
    {
      "filename": "**/*.sh",
      "ignoreRegExpList": ["/[A-Z_]{2,}/g"]
    },
    {
      "filename": "**/.gitignore",
      "enabled": false
    }
  ]
}
