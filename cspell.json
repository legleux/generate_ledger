  "overrides": [
    {
      "filename": "**/*.cu",
      "ignoreRegExpList": [
        "/ULL/g",
        "/__\\w+/g"
      ]
    },
    {
      "filename": "**/.gitignore",
      "enabled": false
    }
  ]
}
